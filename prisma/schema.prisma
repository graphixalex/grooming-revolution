generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

enum DogSize {
  XS
  S
  M
  L
  XL
  XXL
}

enum AppointmentStatus {
  PRENOTATO
  COMPLETATO
  NO_SHOW
  CANCELLATO
}

enum PaymentMethod {
  POS
  CASH
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum ConsentKind {
  DATA_PROCESSING
  PHOTO_INTERNAL
  PHOTO_SOCIAL
}

enum WhatsAppCampaignType {
  MARKETING
  SERVICE
}

enum WhatsAppCampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

enum WhatsAppRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum AppointmentReminderKind {
  DAY_BEFORE_WHATSAPP
}

model SalonGroup {
  id                    String               @id @default(cuid())
  nome                  String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  salons                Salon[]
}

model Salon {
  id                    String               @id @default(cuid())
  salonGroupId          String?
  nomeAttivita          String
  nomeSede              String?
  paese                 String
  timezone              String
  valuta                String               @default("EUR")
  vatRate               Decimal              @default(22)
  vatIncluded           Boolean              @default(true)
  indirizzo             String?
  telefono              String?
  email                 String?
  whatsappTemplate      String?              @db.Text
  whatsappApiEnabled    Boolean              @default(false)
  whatsappApiPhoneNumberId String?
  whatsappApiAccessToken String?             @db.Text
  whatsappApiVersion    String?              @default("v23.0")
  emailTemplate         String?              @db.Text
  overlapAllowed        Boolean              @default(false)
  workingHoursJson      Json?
  holidaysJson          Json?
  subscriptionPlan      SubscriptionPlan     @default(FREE)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  billingVatNumber      String?
  billingCountry        String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  salonGroup            SalonGroup?          @relation(fields: [salonGroupId], references: [id], onDelete: SetNull)
  users                 User[]
  operators             Operator[]
  clients               Client[]
  dogs                  Dog[]
  quickTags             QuickTag[]
  treatments            Treatment[]
  appointments          Appointment[]
  transactions          Transaction[]
  cashSessions          CashSession[]
  priceRules            ServicePriceRule[]
  auditLogs             AuditLog[]
  consentTemplates      ConsentTemplate[]
  clientConsents        ClientConsent[]
  whatsappCampaigns     WhatsAppCampaign[]

  @@index([salonGroupId])
}

model User {
  id            String      @id @default(cuid())
  salonId       String
  displayName   String?
  email         String
  passwordHash  String
  ruolo         UserRole
  createdAt     DateTime    @default(now())

  salon         Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")
  createdTransactions Transaction[] @relation("TransactionCreatedBy")
  openedCashSessions CashSession[] @relation("CashSessionOpenedBy")
  closedCashSessions CashSession[] @relation("CashSessionClosedBy")
  createdPriceRules ServicePriceRule[] @relation("ServicePriceRuleCreatedBy")
  auditLogs     AuditLog[]
  createdClientConsents ClientConsent[] @relation("ClientConsentCreatedBy")
  revokedClientConsents ClientConsent[] @relation("ClientConsentRevokedBy")
  whatsappCampaignsCreated WhatsAppCampaign[]

  @@unique([salonId, email])
  @@index([salonId])
}

model Client {
  id                  String      @id @default(cuid())
  salonId             String
  nome                String
  cognome             String
  telefono            String
  email               String?
  noteCliente         String?     @db.Text
  consensoPromemoria  Boolean     @default(false)
  consensoTimestamp   DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?

  salon               Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  dogs                Dog[]
  appointments        Appointment[]
  consents            ClientConsent[]
  whatsappCampaignRecipients WhatsAppCampaignRecipient[]

  @@index([salonId, deletedAt])
  @@index([salonId, telefono])
  @@index([salonId, nome, cognome])
}

model ConsentTemplate {
  id                  String      @id @default(cuid())
  salonId             String
  kind                ConsentKind
  title               String
  legalText           String      @db.Text
  version             Int         @default(1)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  salon               Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  consents            ClientConsent[]

  @@unique([salonId, kind, version])
  @@index([salonId, kind, isActive])
}

model ClientConsent {
  id                  String      @id @default(cuid())
  salonId             String
  clientId            String
  templateId          String
  kind                ConsentKind
  granted             Boolean
  signerFullName      String
  signerDocumentId    String?
  legalTextSnapshot   String      @db.Text
  templateVersion     Int
  signatureDataUrl    String      @db.Text
  evidenceHash        String
  ipAddress           String?
  userAgent           String?
  signedAt            DateTime
  revokedAt           DateTime?
  revokedReason       String?     @db.Text
  createdById         String
  revokedById         String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  salon               Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client              Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template            ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  createdBy           User        @relation("ClientConsentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  revokedBy           User?       @relation("ClientConsentRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([salonId, clientId, kind, signedAt])
  @@index([clientId, signedAt])
}

model Dog {
  id                  String      @id @default(cuid())
  salonId             String
  clienteId           String
  nome                String
  razza               String?
  taglia              DogSize
  noteCane            String?     @db.Text
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?

  salon               Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  cliente             Client      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tagRapidi           DogQuickTag[]
  appointments        Appointment[]

  @@index([salonId, clienteId, deletedAt])
}

model QuickTag {
  id                  String      @id @default(cuid())
  salonId             String
  nome                String
  ordine              Int         @default(0)
  createdAt           DateTime    @default(now())

  salon               Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  dogs                DogQuickTag[]

  @@unique([salonId, nome])
  @@index([salonId, ordine])
}

model DogQuickTag {
  dogId               String
  quickTagId          String

  dog                 Dog         @relation(fields: [dogId], references: [id], onDelete: Cascade)
  quickTag            QuickTag    @relation(fields: [quickTagId], references: [id], onDelete: Cascade)

  @@id([dogId, quickTagId])
}

model Treatment {
  id                  String      @id @default(cuid())
  salonId             String
  nome                String
  attivo              Boolean     @default(true)
  ordine              Int         @default(0)

  salon               Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments        AppointmentTreatment[]
  priceRules          ServicePriceRule[]

  @@index([salonId, ordine])
}

model Appointment {
  id                  String               @id @default(cuid())
  salonId             String
  operatorId          String?
  clienteId           String
  caneId              String
  startAt             DateTime
  endAt               DateTime
  durataMinuti        Int
  noteAppuntamento    String?              @db.Text
  stato               AppointmentStatus    @default(PRENOTATO)
  createdById         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  salon               Salon                @relation(fields: [salonId], references: [id], onDelete: Cascade)
  operator            Operator?            @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  cliente             Client               @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  cane                Dog                  @relation(fields: [caneId], references: [id], onDelete: Restrict)
  createdBy           User                 @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  trattamentiSelezionati AppointmentTreatment[]
  transactions        Transaction[]
  reminders           AppointmentReminder[]

  @@index([salonId, startAt, endAt])
  @@index([salonId, operatorId, startAt])
  @@index([salonId, clienteId])
  @@index([salonId, caneId])
  @@index([salonId, stato])
}

model AppointmentReminder {
  id                  String                 @id @default(cuid())
  appointmentId       String
  kind                AppointmentReminderKind
  status              WhatsAppRecipientStatus @default(PENDING)
  attemptCount        Int                    @default(0)
  messageId           String?
  errorMessage        String?
  lastAttemptAt       DateTime?
  sentAt              DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  appointment         Appointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, kind])
  @@index([kind, status])
}

model Operator {
  id                  String      @id @default(cuid())
  salonId             String
  nome                String
  attivo              Boolean     @default(true)
  ordine              Int         @default(0)
  color               String?     @default("#2563eb")
  workingHoursJson    Json?
  kpiTargetRevenue    Decimal?    @db.Decimal(10, 2)
  kpiTargetAppointments Int?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  salon               Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments        Appointment[]

  @@index([salonId, ordine])
  @@unique([salonId, nome])
}

model AppointmentTreatment {
  appointmentId       String
  treatmentId         String

  appointment         Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  treatment           Treatment    @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@id([appointmentId, treatmentId])
}

model Transaction {
  id                  String        @id @default(cuid())
  salonId             String
  appointmentId       String
  cashSessionId       String?
  amount              Decimal       @db.Decimal(10, 2)
  tipAmount           Decimal       @default(0) @db.Decimal(10, 2)
  method              PaymentMethod
  vatRate             Decimal       @db.Decimal(5, 2)
  vatAmount           Decimal       @db.Decimal(10, 2)
  netAmount           Decimal       @db.Decimal(10, 2)
  grossAmount         Decimal       @db.Decimal(10, 2)
  dateTime            DateTime
  note                String?
  createdById         String
  createdAt           DateTime      @default(now())

  salon               Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointment         Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  cashSession         CashSession?  @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  createdBy           User          @relation("TransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([salonId, dateTime])
  @@index([cashSessionId])
}

model ServicePriceRule {
  id                  String        @id @default(cuid())
  salonId             String
  treatmentId         String
  dogSize             DogSize?
  razzaPattern        String?
  extraLabel          String?
  basePrice           Decimal       @db.Decimal(10, 2)
  extraPrice          Decimal       @default(0) @db.Decimal(10, 2)
  durataMinuti        Int
  validoDa            DateTime
  validoA             DateTime?
  attiva              Boolean       @default(true)
  note                String?
  createdById         String
  createdAt           DateTime      @default(now())

  salon               Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  treatment           Treatment     @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  createdBy           User          @relation("ServicePriceRuleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([salonId, attiva, validoDa, validoA])
  @@index([salonId, treatmentId, dogSize])
}

model CashSession {
  id                  String            @id @default(cuid())
  salonId             String
  openedById          String
  closedById          String?
  status              CashSessionStatus @default(OPEN)
  openingFloat        Decimal           @db.Decimal(10, 2)
  closingExpected     Decimal?          @db.Decimal(10, 2)
  closingCounted      Decimal?          @db.Decimal(10, 2)
  difference          Decimal?          @db.Decimal(10, 2)
  noteApertura        String?
  noteChiusura        String?
  openedAt            DateTime          @default(now())
  closedAt            DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  salon               Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  openedBy            User              @relation("CashSessionOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedBy            User?             @relation("CashSessionClosedBy", fields: [closedById], references: [id], onDelete: Restrict)
  transactions        Transaction[]

  @@index([salonId, status, openedAt])
}

model AuditLog {
  id                  String      @id @default(cuid())
  salonId             String
  userId              String
  action              String
  entityType          String
  entityId            String
  metaJson            Json?
  createdAt           DateTime    @default(now())

  salon               Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([salonId, createdAt])
}

model WhatsAppCampaign {
  id                  String                 @id @default(cuid())
  salonId             String
  createdById         String
  type                WhatsAppCampaignType
  title               String
  messageTemplate     String                 @db.Text
  status              WhatsAppCampaignStatus @default(DRAFT)
  totalRecipients     Int                    @default(0)
  sentCount           Int                    @default(0)
  failedCount         Int                    @default(0)
  skippedCount        Int                    @default(0)
  createdAt           DateTime               @default(now())
  startedAt           DateTime?
  completedAt         DateTime?

  salon               Salon                  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdBy           User                   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  recipients          WhatsAppCampaignRecipient[]

  @@index([salonId, createdAt])
  @@index([salonId, status])
}

model WhatsAppCampaignRecipient {
  id                  String                 @id @default(cuid())
  campaignId          String
  clientId            String
  phone               String
  renderedMessage     String                 @db.Text
  status              WhatsAppRecipientStatus @default(PENDING)
  errorMessage        String?
  messageId           String?
  attemptCount        Int                    @default(0)
  lastAttemptAt       DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  campaign            WhatsAppCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  client              Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([campaignId, clientId])
  @@index([campaignId, status])
}

